rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function orgId() {
      return request.auth.token.orgId;
    }

    function profileOrgId() {
      return signedIn()
             && exists(/databases/$(database)/documents/users/$(request.auth.uid))
             ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active_org_id
             : null;
    }

    function role() {
      return request.auth.token.role;
    }

    function profileRole() {
      return signedIn()
             && exists(/databases/$(database)/documents/users/$(request.auth.uid))
             ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
             : null;
    }

    function profileEmailLower() {
      return signedIn()
             && exists(/databases/$(database)/documents/users/$(request.auth.uid))
             ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email_lower
             : null;
    }

    function requestOrgMembershipRole() {
      return signedIn()
             && request.resource.data.org_id is string
             && exists(
                  /databases/$(database)/documents/organization_members/
                  $(request.resource.data.org_id + "_" + request.auth.uid)
                )
             && get(
                  /databases/$(database)/documents/organization_members/
                  $(request.resource.data.org_id + "_" + request.auth.uid)
                ).data.status == 'active'
             ? get(
                  /databases/$(database)/documents/organization_members/
                  $(request.resource.data.org_id + "_" + request.auth.uid)
                ).data.role
             : null;
    }

    function resourceOrgMembershipRole() {
      return signedIn()
             && resource.data.org_id is string
             && exists(
                  /databases/$(database)/documents/organization_members/
                  $(resource.data.org_id + "_" + request.auth.uid)
                )
             && get(
                  /databases/$(database)/documents/organization_members/
                  $(resource.data.org_id + "_" + request.auth.uid)
                ).data.status == 'active'
             ? get(
                  /databases/$(database)/documents/organization_members/
                  $(resource.data.org_id + "_" + request.auth.uid)
                ).data.role
             : null;
    }

    function sameOrgFromResource() {
      return signedIn() && (
               resource.data.org_id == orgId()
               || resource.data.org_id == profileOrgId()
             );
    }

    function sameOrgFromRequest() {
      return signedIn() && (
               request.resource.data.org_id == orgId()
               || request.resource.data.org_id == profileOrgId()
             );
    }

    function isViewer() {
      return role() in ['member', 'viewer', 'cashier', 'manager', 'admin'];
    }

    function isCashier() {
      return role() in ['cashier', 'manager', 'admin'];
    }

    function isManager() {
      return role() in ['manager', 'admin']
             || profileRole() in ['manager', 'admin'];
    }

    function isAdmin() {
      return role() == 'admin' || profileRole() == 'admin';
    }

    function isResourceOrgViewer() {
      return resourceOrgMembershipRole() in ['viewer', 'member', 'cashier', 'manager', 'admin', 'owner'];
    }

    function isRequestOrgCashier() {
      return requestOrgMembershipRole() in ['cashier', 'manager', 'admin', 'owner'];
    }

    function isResourceOrgCashier() {
      return resourceOrgMembershipRole() in ['cashier', 'manager', 'admin', 'owner'];
    }

    function isRequestOrgManager() {
      return requestOrgMembershipRole() in ['manager', 'admin', 'owner'];
    }

    function immutableOnUpdate(field) {
      return request.resource.data[field] == resource.data[field];
    }

    function cashierStockMutationOnly() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
               'current_stock',
               'updated_at',
               'updated_by'
             ])
             && request.resource.data.current_stock is int
             && request.resource.data.current_stock <= resource.data.current_stock
             && request.resource.data.updated_by == request.auth.uid;
    }

    function validMovementType(value) {
      return value in ['sale_parent', 'compound_consumption', 'service_sale'];
    }

    function validParentItemType(value) {
      return value in ['stock', 'compound', 'service'];
    }

    // ORGANIZATIONS
    // Create is restricted to authenticated admins only.
    match /organizations/{organizationId} {
      allow read: if signedIn();
      allow create: if signedIn()
                    && isAdmin()
                    && request.resource.data.created_by == request.auth.uid;
      allow update, delete: if signedIn() && isAdmin();
    }

    // ORGANIZATION_MEMBERS
    match /organization_members/{membershipId} {
      allow read: if signedIn() && (
                    resource.data.user_id == request.auth.uid
                    || isAdmin()
                  );
      allow create: if signedIn() && (
                      isAdmin()
                      || (
                        request.resource.data.user_id == request.auth.uid
                        && request.resource.data.role == 'member'
                        && request.resource.data.status == 'active'
                        && request.resource.data.email_lower == profileEmailLower()
                        && getAfter(
                             /databases/$(database)/documents/organization_invitations/
                             $(request.resource.data.org_id + "_" + request.resource.data.email_lower)
                           ).data.status == 'accepted'
                        && getAfter(
                             /databases/$(database)/documents/organization_invitations/
                             $(request.resource.data.org_id + "_" + request.resource.data.email_lower)
                           ).data.invited_user_id == request.auth.uid
                        && getAfter(
                             /databases/$(database)/documents/organization_invitations/
                             $(request.resource.data.org_id + "_" + request.resource.data.email_lower)
                           ).data.org_id == request.resource.data.org_id
                      )
                    );
      allow update, delete: if signedIn() && isAdmin();
    }

    // ORGANIZATION_INVITATIONS
    match /organization_invitations/{invitationId} {
      allow read: if signedIn() && (
                    isAdmin()
                    || resource.data.email_lower == profileEmailLower()
                  );

      allow create: if signedIn() && isAdmin() && sameOrgFromRequest();

      allow update: if signedIn() && (
                      isAdmin()
                      || (
                        resource.data.email_lower == profileEmailLower()
                        && request.resource.data.email_lower == resource.data.email_lower
                        && request.resource.data.org_id == resource.data.org_id
                        && request.resource.data.email == resource.data.email
                        && request.resource.data.role == resource.data.role
                        && request.resource.data.invited_by == resource.data.invited_by
                        && resource.data.status == 'pending'
                        && request.resource.data.status in ['accepted', 'rejected']
                        && request.resource.data.invited_user_id == request.auth.uid
                      )
                    );

      allow delete: if signedIn() && isAdmin();
    }

    // PRODUCTS
    match /products/{productId} {
      allow read: if sameOrgFromResource() && (isViewer() || isResourceOrgViewer());
      allow create: if sameOrgFromRequest() && (isManager() || isRequestOrgManager());
      allow update: if sameOrgFromResource()
                    && sameOrgFromRequest()
                    && (
                      (
                        (isManager() || isRequestOrgManager())
                        && immutableOnUpdate('created_at')
                        && immutableOnUpdate('created_by')
                      )
                      ||
                      (
                        (isCashier() || isRequestOrgCashier())
                        && cashierStockMutationOnly()
                      )
                    );
      allow delete: if sameOrgFromResource() && isAdmin();
    }

    // SALES (append-only)
    match /sales/{saleId} {
      allow read: if sameOrgFromResource() && isCashier();
      allow create: if sameOrgFromRequest()
                    && isCashier()
                    && request.resource.data.sold_by == request.auth.uid;
      allow update, delete: if false;
    }

    // COMPOUND_PRODUCT_RECIPES
    match /compound_product_recipes/{recipeId} {
      allow read: if sameOrgFromResource() && (isViewer() || isResourceOrgViewer());
      allow create, update: if sameOrgFromRequest()
                            && (isManager() || isRequestOrgManager())
                            && request.resource.data.updated_by == request.auth.uid;
      allow delete: if sameOrgFromResource() && isAdmin();
    }

    // SALE_INVENTORY_MOVEMENTS (append-only)
    match /sale_inventory_movements/{movementId} {
      allow read: if sameOrgFromResource() && isCashier();
      allow create: if sameOrgFromRequest()
                    && isCashier()
                    && request.resource.data.moved_by == request.auth.uid
                    && validMovementType(request.resource.data.movement_type)
                    && validParentItemType(request.resource.data.parent_item_type);
      allow update, delete: if false;
    }

    // RESTOCK_LOGS (append-only)
    match /restock_logs/{restockId} {
      allow read: if sameOrgFromResource() && (isCashier() || isResourceOrgCashier());
      allow create: if sameOrgFromRequest()
                    && (isManager() || isRequestOrgManager())
                    && request.resource.data.restocked_by == request.auth.uid;
      allow update, delete: if false;
    }

    // PRODUCT_CHANGE_LOGS (append-only)
    match /product_change_logs/{logId} {
      allow read: if sameOrgFromResource() && (isCashier() || isResourceOrgCashier());
      allow create: if sameOrgFromRequest()
                    && (isManager() || isRequestOrgManager())
                    && request.resource.data.changed_by == request.auth.uid
                    && request.resource.data.event_type in ['created', 'updated', 'stock_added'];
      allow update, delete: if false;
    }

    // USERS
    match /users/{uid} {
      allow read: if signedIn()
                  && (
                    uid == request.auth.uid
                    || (sameOrgFromResource() && isManager())
                  );

      allow create: if signedIn()
                    && uid == request.auth.uid
                    && request.resource.data.role in ['admin', 'viewer'];

      allow update: if signedIn() && (
                    (uid == request.auth.uid
                      && immutableOnUpdate('role'))
                    ||
                    (sameOrgFromResource() && sameOrgFromRequest() && isAdmin())
                  );

      allow delete: if sameOrgFromResource() && isAdmin();
    }

    // AUDIT_LOGS (append-only)
    match /audit_logs/{auditId} {
      allow read: if sameOrgFromResource() && isManager();
      allow create: if sameOrgFromRequest()
                    && isCashier()
                    && request.resource.data.actor_uid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
